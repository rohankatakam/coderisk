# ========================================
# COGNEE CONFIGURATION TEMPLATE
# ========================================
# Copy this file to .env and configure your preferred providers
# All sections are optional - Cognee will use defaults if not specified

# ========================================
# LLM PROVIDERS
# ========================================
# Choose one LLM provider configuration

# OpenAI (Default - Recommended)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here

# Azure OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=azure/gpt-4o-mini
# LLM_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o-mini
# LLM_API_KEY=your_azure_api_key_here
# LLM_API_VERSION=2024-12-01-preview

# Google Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=your_google_api_key_here

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=your_anthropic_api_key_here

# Ollama (Local)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama

# Custom Provider (e.g., OpenRouter)
# LLM_PROVIDER=custom
# LLM_MODEL=openrouter/google/gemini-2.0-flash-lite-preview-02-05:free
# LLM_ENDPOINT=https://openrouter.ai/api/v1
# LLM_API_KEY=your_custom_api_key_here

# ========================================
# STRUCTURED OUTPUT BACKENDS
# ========================================
# Choose structured output framework

# LiteLLM + Instructor (Default)
STRUCTURED_OUTPUT_FRAMEWORK=instructor

# BAML (Build-A-Model Language)
# STRUCTURED_OUTPUT_FRAMEWORK=baml

# ========================================
# EMBEDDING PROVIDERS
# ========================================
# Choose embedding provider (defaults to match LLM provider)

# OpenAI Embeddings (Default)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=your_openai_api_key_here

# Azure OpenAI Embeddings
# EMBEDDING_PROVIDER=azure
# EMBEDDING_MODEL=azure/text-embedding-3-large
# EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/text-embedding-3-large
# EMBEDDING_API_KEY=your_azure_api_key_here
# EMBEDDING_API_VERSION=2024-12-01-preview
# EMBEDDING_DIMENSIONS=3072

# Google Gemini Embeddings
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini/text-embedding-004
# EMBEDDING_API_KEY=your_google_api_key_here
# EMBEDDING_DIMENSIONS=768

# Mistral Embeddings
# EMBEDDING_PROVIDER=mistral
# EMBEDDING_MODEL=mistral/mistral-embed
# EMBEDDING_API_KEY=your_mistral_api_key_here
# EMBEDDING_DIMENSIONS=1024

# Ollama Local Embeddings
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=avr/sfr-embedding-mistral:latest
# EMBEDDING_ENDPOINT=http://localhost:11434/v1
# EMBEDDING_API_KEY=ollama
# EMBEDDING_DIMENSIONS=4096

# Fastembed (CPU-friendly local)
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384

# Custom Embedding Provider
# EMBEDDING_PROVIDER=custom
# EMBEDDING_MODEL=your_custom_model
# EMBEDDING_ENDPOINT=your_custom_endpoint
# EMBEDDING_API_KEY=your_custom_api_key
# EMBEDDING_DIMENSIONS=your_model_dimensions

# ========================================
# RELATIONAL DATABASES
# ========================================
# Choose relational database for metadata storage

# SQLite (Default - for development)
DB_PROVIDER=sqlite
DB_NAME=coderisk_db

# PostgreSQL (Recommended for production)
# DB_PROVIDER=postgres
# DB_NAME=coderisk_db
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USERNAME=cognee
# DB_PASSWORD=your_postgres_password

# ========================================
# VECTOR STORES
# ========================================
# Choose vector store for embeddings

# LanceDB (Default - file-based)
VECTOR_DB_PROVIDER=lancedb

# PGVector (requires PostgreSQL + pgvector extension)
# VECTOR_DB_PROVIDER=pgvector
# Uses same DB connection as relational database above

# ChromaDB (requires running Chroma server)
# VECTOR_DB_PROVIDER=chromadb
# VECTOR_DB_URL=http://localhost:3002
# VECTOR_DB_KEY=your_chroma_token

# FalkorDB (hybrid graph + vector)
# VECTOR_DB_PROVIDER=falkordb
# VECTOR_DB_URL=your_falkordb_url
# VECTOR_DB_KEY=your_falkordb_key

# Neptune Analytics (Amazon)
# VECTOR_DB_PROVIDER=neptune_analytics
# VECTOR_DB_URL=your_neptune_url
# AWS credentials required

# ========================================
# GRAPH STORES
# ========================================
# Choose graph database for relationships

# Kuzu (Default - file-based)
GRAPH_DATABASE_PROVIDER=kuzu

# Kuzu Remote (HTTP API)
# GRAPH_DATABASE_PROVIDER=kuzu-remote
# GRAPH_DATABASE_URL=http://localhost:8000

# Neo4j (Production graph database)
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_URL=bolt://localhost:7687
# GRAPH_DATABASE_NAME=neo4j
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=your_neo4j_password

# Amazon Neptune
# GRAPH_DATABASE_PROVIDER=neptune
# GRAPH_DATABASE_URL=your_neptune_cluster_endpoint
# AWS credentials required

# Neptune Analytics
# GRAPH_DATABASE_PROVIDER=neptune_analytics
# GRAPH_DATABASE_URL=your_neptune_analytics_endpoint
# AWS credentials required

# ========================================
# COGNEE SYSTEM CONFIGURATION
# ========================================
# Optional system-level settings

# System directory (default: ~/.cognee_system)
# SYSTEM_ROOT_DIRECTORY=/absolute/path/.cognee_system

# Logging level
# LOG_LEVEL=INFO

# ========================================
# OBSERVABILITY & MONITORING
# ========================================
# Configuration for tracing and monitoring with Langfuse

# Langfuse Configuration (for tracing and observability)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ========================================
# CODERISK SPECIFIC CONFIGURATION
# ========================================
# Configuration specific to CodeRisk application

# Enable full Cognee integration (REQUIRED - no fallback)
CODERISK_USE_COGNEE=true

# Enable advanced mathematical calculations
CODERISK_USE_ADVANCED_CALCULATIONS=true

# Repository analysis window (days)
CODERISK_ANALYSIS_WINDOW_DAYS=90

# Performance limits
CODERISK_GRAPH_QUERY_TIMEOUT_MS=500
CODERISK_MAX_GRAPH_HOPS=2
CODERISK_MAX_GRAPH_DEGREE=200

# Auto-high thresholds
CODERISK_AUTO_HIGH_FILE_COUNT=20
CODERISK_AUTO_HIGH_API_SCORE=0.9
CODERISK_AUTO_HIGH_SCHEMA_SCORE=0.9
CODERISK_AUTO_HIGH_SECURITY_SCORE=0.9

# ========================================
# COMPATIBLE CONFIGURATIONS
# ========================================
# Recommended combinations for different use cases:

# DEVELOPMENT (Local, Fast)
# - LLM: OpenAI (gpt-4o-mini)
# - Embedding: OpenAI (text-embedding-3-large)
# - DB: SQLite
# - Vector: LanceDB
# - Graph: Kuzu

# PRODUCTION (Scalable, Robust)
# - LLM: OpenAI (gpt-4o)
# - Embedding: OpenAI (text-embedding-3-large)
# - DB: PostgreSQL
# - Vector: PGVector
# - Graph: Neo4j

# COST-OPTIMIZED (Local/Self-hosted)
# - LLM: Ollama (llama3.1:8b)
# - Embedding: Fastembed (local)
# - DB: SQLite
# - Vector: LanceDB
# - Graph: Kuzu

# CLOUD-NATIVE (AWS)
# - LLM: OpenAI
# - Embedding: OpenAI
# - DB: PostgreSQL (RDS)
# - Vector: PGVector
# - Graph: Neptune

# PRIVACY-FIRST (No external APIs)
# - LLM: Ollama (local)
# - Embedding: Fastembed (local)
# - DB: SQLite
# - Vector: LanceDB
# - Graph: Kuzu